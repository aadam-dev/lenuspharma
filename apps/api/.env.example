# PostgreSQL (production & local). Example:
# DATABASE_URL="postgresql://lenus:lenus@localhost:5432/lenus_pharmacy?schema=public"
DATABASE_URL="postgresql://user:password@localhost:5432/lenus_pharmacy?schema=public"

PORT=4000
# Comma-separated origins or "true" for reflect request origin (dev only)
CORS_ORIGIN=http://localhost:3000

# Public URL of the Next.js app (Paystack callback)
APP_PUBLIC_URL=http://localhost:3000

# Required in production
JWT_SECRET=change-me-to-a-long-random-string

# Paystack (https://paystack.com)
PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=pk_test_xxx  # used by client if you add inline card form later

# Optional: Hubtel SMS (https://hubtel.com)
# HUBTEL_CLIENT_ID=
# HUBTEL_CLIENT_SECRET=
# HUBTEL_FROM_NUMBER=

# Low-stock threshold for admin alerts
LOW_STOCK_THRESHOLD=10

# Bootstrap staff on `npm run db:seed` (recommended for first deploy only)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=Operations Admin
# BOOTSTRAP_PHARMACIST_EMAIL=pharmacist@example.com
# BOOTSTRAP_PHARMACIST_PASSWORD=
# BOOTSTRAP_PHARMACIST_NAME=Lead Pharmacist
