{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:ensure": "tsx prisma/ensure-branches.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "@lenus/shared": "*",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.0.0",
    "fastify": "^4.24.0",
    "fastify-raw-body": "^4.3.0",
    "@prisma/client": "^5.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "prisma": "^5.7.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
