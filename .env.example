# Copy to apps/api/.env and apps/web/.env.local as needed (never commit real secrets).

# --- API (apps/api) ---
DATABASE_URL="postgresql://lenus:lenus@localhost:5432/lenus_pharmacy?schema=public"
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
JWT_SECRET=dev-only-change-in-production

# Paystack
# PAYSTACK_SECRET_KEY=sk_test_xxx

# Optional SMS (Hubtel)
# HUBTEL_CLIENT_ID=
# HUBTEL_CLIENT_SECRET=
# HUBTEL_FROM_NUMBER=

LOW_STOCK_THRESHOLD=10

# Seed bootstrap (first run only)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_PHARMACIST_EMAIL=
# BOOTSTRAP_PHARMACIST_PASSWORD=

# --- Web (apps/web → .env.local) ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000/api
